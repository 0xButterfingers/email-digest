# ===========================================
# PRODUCTION .env  — copy to .env and fill in
# Replace YOUR_DROPLET_IP with the actual IP
# ===========================================

APP_NAME=Email Digest Summarizer
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Database (stored in Docker volume)
DATABASE_URL=sqlite+aiosqlite:///./data/email_digest.db

# Gmail OAuth2  — update redirect URI to production IP
GMAIL_CLIENT_ID=YOUR_GMAIL_CLIENT_ID.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=YOUR_GMAIL_CLIENT_SECRET
GMAIL_REDIRECT_URI=http://YOUR_DROPLET_IP/api/auth/gmail/callback

# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Twilio (WhatsApp) — optional
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890

# Discord — optional
DISCORD_WEBHOOK_URL=https://discordapp.com/api/webhooks/...

# CORS — allow the Droplet IP
CORS_ORIGINS=["http://YOUR_DROPLET_IP","http://localhost:8000"]

# Scheduler
SCHEDULER_TIMEZONE=Asia/Singapore
SCHEDULER_POOL_SIZE=10
